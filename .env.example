# ════════════════════════════════════════════════════════════════════════════
# TrustHire AI — Environment Variables
# Copy this file to .env and fill in your values.
# Voice calls removed. No Ollama/GPU needed — uses free cloud LLMs.
# ════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
DOMAIN=localhost

# ── Google OAuth (REQUIRED for login) ─────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → OAuth 2.0 Client IDs
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth (auto-generated by setup.sh) ─────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=password

# ══════════════════════════════════════════════════════════════════════════════
# FREE LLM PROVIDER — choose ONE and set the corresponding API key
# ══════════════════════════════════════════════════════════════════════════════

LLM_PROVIDER=gemini   # Options: gemini | groq | mistral | cohere | together

# ── Option 1: Google Gemini (RECOMMENDED — best free tier) ────────────────
# Free: 1,000,000 tokens/day, 1,500 req/day, 15 req/min
# Sign up FREE: https://aistudio.google.com/app/apikey  (just Google login)
# No credit card required for free tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash         # fastest, best for extraction tasks
GEMINI_MODEL_PRO=gemini-1.5-pro       # smarter, used for fraud analysis (50 req/day free)

# ── Option 2: Groq (FASTEST inference, great alternative) ─────────────────
# Free: 14,400 requests/day, 30 req/min — runs Llama 3 at 500+ tokens/sec
# Sign up FREE: https://console.groq.com  (GitHub login)
# No credit card required
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant       # fastest
GROQ_MODEL_LARGE=llama-3.3-70b-versatile  # smarter (used for complex tasks)

# ── Option 3: Mistral AI (good quality, generous free tier) ───────────────
# Free tier available with rate limiting
# Sign up: https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ── Option 4: Cohere (reliable, free trial) ───────────────────────────────
# Free: 20 req/min, 1,000 req/month on trial key
# Sign up: https://dashboard.cohere.com
COHERE_API_KEY=
COHERE_MODEL=command-r

# ── Option 5: Together AI ($25 free credit on signup) ─────────────────────
# Sign up: https://api.together.xyz
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# ══════════════════════════════════════════════════════════════════════════════
# END LLM PROVIDER SECTION
# ══════════════════════════════════════════════════════════════════════════════

# ── MinIO Object Storage (FREE, self-hosted) ──────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ── Email (Resend — 3,000 free emails/month) ──────────────────────────────────
# Sign up FREE: https://resend.com (no credit card)
EMAIL_PROVIDER=smtp                 # smtp | resend
RESEND_API_KEY=                     # set this if using resend
FROM_EMAIL=verify@yourdomain.com

# SMTP fallback (Gmail app password — not your regular password)
# Enable at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Encryption (REQUIRED — auto-generated by setup.sh) ────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
FLOWER_USER=admin
FLOWER_PASS=admin
