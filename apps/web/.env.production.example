# Copy this to Render environment variables for the web service

NEXTAUTH_URL=https://trusthire-web.onrender.com
NEXTAUTH_SECRET=<generate: openssl rand -base64 32>
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
NEXT_PUBLIC_API_URL=https://trusthire-api.onrender.com
DATABASE_URL=<Neon postgresql+asyncpg:// connection string>
NODE_ENV=production
